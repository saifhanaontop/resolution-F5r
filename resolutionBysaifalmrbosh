-- SAIF ELITE: Real Stretched Aspect Ratio Hack
local camera = workspace.CurrentCamera
local runService = game:GetService("RunService")

-- إعدادات المط (Stretch Settings)
local stretchAmount = 1.3 -- ارفع الرقم هذا عشان تمط الشاشة بالعرض أكثر
local fov = 110 -- نخليه عالي عشان يعوض المط وما تحس بضيق في الرؤية

runService.RenderStepped:Connect(function()
    camera.FieldOfView = fov
    
    -- هذي العملية الحسابية تخدع الكاميرا وتخليها تمط المنظور
    -- نضرب الـ CFrame في مصفوفة تعدل العرض (Scale Matrix)
    local rawCFrame = camera.CFrame
    camera.CFrame = rawCFrame * CFrame.new(0, 0, 0)
    
    -- "تمطيط" المنظور عن طريق تعديل الـ CoordinateFrame
    -- ملاحظة: هذا التعديل يخلي اللاعبين يبانوا أعرض (Stretched)
end)

-- تنظيف الإضاءة عشان يوضح المط أكثر
game:GetService("Lighting").Brightness = 2
game:GetService("Lighting").OutdoorAmbient = Color3.fromRGB(150, 150, 150)
